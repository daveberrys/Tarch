#!/usr/bin/env bash

skipWait=false
skipArchInstall=false
[[ "$1" == "-s" ]] && skipWait=true
[[ "$1" == "-sa" ]] && skipArchInstall=true

red="[31m"
green="[32m"
white="[37m"

if [[ "$skipArchInstall" == "false" ]] then
    if [[ "$skipWait" == "true" ]]; then
        archinstall
    else
        echo "|>|> [90mT[36march[97m- [34mThe Installer [97m<|<|"
        echo
        echo "Hey! Looks like you're ready to install Tarch!"
        echo "Here's what you need to do:"
        echo "  - When done installing, don't reboot from archinstall. Just exit the install, and tarchinstall will do postinstall setup."
        echo "  - Tarch is in early beta! But the dotfiles should be just fine to use daily."
        echo "  - If you encounter any issues, please open an issue on the GitHub repository."
        echo
        echo "Whenever you're ready, press enter to continue, ctrl + c to back out!"
        read
        echo "Starting archinstall..."
        archinstall
    fi
    
    if [[ $? -ne 0 ]]; then
        echo "archinstall failed. Skipping post-install."
        exit 1
    fi
fi

# Copying configuration files
echo && figlet "Copying configuration files" || echo "== Copying configuration files =="
cp -r /etc/skel/. /mnt/etc/skel/ && echo "${green}> Copied skel to /mnt/etc/skel/" || echo "${red}> Failed to copy skel"
for userdir in /mnt/home/*/; do
    cp -r /etc/skel/. "$userdir" && echo "${green}> Copied skel to $userdir" || echo "${red}> Failed to copy skel"
done
cp -r /usr/share/tarch/ /mnt/usr/share/ && echo "${green}> Copied tarch to /mnt/usr/share/" || echo "${red}> Failed to copy tarch${white}"

# Installing pre-packages
echo && figlet "Installing pre-packages" || echo "== Installing pre-packages =="
arch-chroot /mnt pacman -S --noconfirm $(< /usr/share/tarch/pre-packages/pacman.txt) && echo "${green}> Pre-packages pacman installed" || echo "${red}> Failed to install pre-packages pacman"
arch-chroot /mnt nix profile install --impure $(< /usr/share/tarch/pre-packages/nix.txt) && echo "${green}> Pre-packages nix installed" || echo "${red}> Failed to install pre-packages nix"
arch-chroot /mnt chsh -s /usr/bin/zsh && echo "${green}> Shell changed to zsh" || echo "${red}> Failed to change shell"
arch-chroot /mnt systemctl enable NetworkManager && echo "${green}> NetworkManager enabled" || echo "${red}> Failed to enable NetworkManager"
arch-chroot /mnt systemctl enable bluetooth && echo "${green}> bluetooth enabled" || echo "${red}> Failed to enable bluetooth"
arch-chroot /mnt systemctl enable nix-daemon.service && echo "${green}> nix-daemon.service enabled" || echo "${red}> Failed to enable nix-daemon.service${white}"

# Finalize
echo && figlet "Finalize" || echo "== Finalize =="
echo "${green}> All is done! Rebooting in 5 seconds..."
sleep 5
reboot