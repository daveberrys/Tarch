#!/usr/bin/env bash

skipWait=false
skipArchInstall=false
[[ "$1" == "-s" ]] && skipWait=true
[[ "$1" == "-sa" ]] && skipArchInstall=true

red="[31m"
green="[32m"
reset="[0m"

if [[ "$skipArchInstall" == "false" ]] then
    if [[ "$skipWait" == "true" ]]; then
        archinstall
    else
        echo "|>|> [90mT[36march[97m- [34mThe Installer [97m<|<|"
        echo
        echo "Hey! Looks like you're ready to install [90mT[36march[97m!"
        echo "Here's what you need to do:"
        echo "  - When done installing, don't reboot from archinstall. Just exit the install, and tarchinstall will do postinstall setup."
        echo "  - Tarch is in early beta! But the dotfiles should be just fine to use daily."
        echo "  - If you encounter any issues, please open an issue on the GitHub repository."
        echo
        echo "Whenever you're ready, press enter to continue, ctrl + c to back out!"
        read
        echo "Starting archinstall..."
        archinstall
    fi
    
    if [[ $? -ne 0 ]]; then
        echo "archinstall failed. Skipping post-install."
        exit 1
    fi
fi

tarchecho () {
    if [[ $1 == "success" ]]; then
        echo "${green}> $2 ${reset}"
    elif [[ $1 == "failure" ]]; then
        echo "${red}> $2 ${reset}"
    else
        echo "${reset}> $2 ${reset}"
    fi
}

# Copying configuration files
echo && figlet "Copying configuration files" || echo "== Copying configuration files =="
cp -r /etc/skel/. /mnt/etc/skel/ && tarchecho success "Copied skel to /mnt/etc/skel/" || tarchecho failure "Failed to copy skel"
for userdir in /mnt/home/*/; do
    cp -r /etc/skel/. "$userdir" && tarchecho success "Copied skel to $userdir" || tarchecho failure "Failed to copy skel"
done
cp -r /usr/share/tarch/ /mnt/usr/share/ && tarchecho success "Copied tarch to /mnt/usr/share/" || tarchecho failure "Failed to copy tarch"

# Installing pre-packages and services
echo && figlet "Installing pre-packages and services" || echo "== Installing pre-packages and services =="
arch-chroot /mnt pacman -S --noconfirm $(< /usr/share/tarch/pre-packages/pacman.txt) && tarchecho success "Pre-packages pacman installed" || tarchecho failure "Failed to install pre-packages pacman"

arch-chroot /mnt systemctl enable NetworkManager && tarchecho success "NetworkManager enabled" || tarchecho failure "Failed to enable NetworkManager"
arch-chroot /mnt systemctl enable bluetooth && tarchecho success "bluetooth enabled" || tarchecho failure "Failed to enable bluetooth"
arch-chroot /mnt systemctl enable nix-daemon.service && tarchecho success "nix-daemon.service enabled" || tarchecho failure "Failed to enable nix-daemon.service"

mkdir -p /mnt/etc/nix && tarchecho success "Nix config directory created" || tarchecho failure "Failed to create Nix config directory"
echo "experimental-features = nix-command flakes" >> /mnt/etc/nix/nix.conf && tarchecho success "Nix config updated" || tarchecho failure "Failed to update Nix config"
arch-chroot /mnt nix profile install --no-sandbox --impure $(< /usr/share/tarch/pre-packages/nix.txt) && tarchecho success "Pre-packages nix installed" || tarchecho failure "Failed to install pre-packages nix"

# Finalizing
echo && figlet "Finalizing" || echo "== Finalizing =="

arch-chroot /mnt chsh -s /usr/bin/zsh && tarchecho success "Shell changed to zsh (may not actually change in your user...)" || tarchecho failure "Failed to change shell"
for userdir in /mnt/home/*/; do
    echo 'export NIXPKGS_ALLOW_UNFREE=1
alias nixpi="nix profile install --impure"
alias nixpr="nix profile remove"
alias nixps="nix search"
alias nixpu="nix profile upgrade"' >> "$userdir/.zshrc" && tarchecho success "Zsh config updated" || tarchecho failure "Failed to update Zsh config"
done

arch-chroot /mnt sudo systemctl enable greetd && tarchecho success "greetd enabled" || tarchecho failure "Failed to enable greetd"
mkdir -p /mnt/etc/greetd && tarchecho success "greetd config directory created" || tarchecho failure "Failed to create greetd config directory"
echo '[terminal]
vt = 1

[default_session]
command = "env GTK_THEME=Adwaita:dark cage -s -- /usr/bin/gtkgreet"
user = "greeter"' >> /mnt/etc/greetd/config.toml && tarchecho success "greetd config created" || tarchecho failure "Failed to create greetd config"
arch-chroot /mnt sudo useradd -m greeter && tarchecho success "greeter user created" || tarchecho failure "Failed to create greeter user"
arch-chroot /mnt sudo usermod -aG video greeter && tarchecho success "greeter user added to video group" || tarchecho failure "Failed to add greeter user to video group"

setDarkMode='[Settings]
gtk-theme-name=Adwaita
gtk-application-prefer-dark-theme=1'
echo "$setDarkMode" >> /mnt/var/lib/greeter/.config/gtk-3.0/settings.ini && tarchecho success "GTK 3.0 settings updated for greeter" || tarchecho failure "Failed to update GTK 3.0 settings for greeter"
echo "$setDarkMode" >> /mnt/var/lib/greeter/.config/gtk-4.0/settings.ini && tarchecho success "GTK 4.0 settings updated for greeter" || tarchecho failure "Failed to update GTK 4.0 settings for greeter"
arch-chroot /mnt sudo chown -R greeter:greeter /var/lib/greeter/ && tarchecho success "greeter user ownership updated" || tarchecho failure "Failed to update greeter user ownership"
arch-chroot /mnt sudo usermod -d /var/lib/greeter greeter && tarchecho success "greeter user updated" || tarchecho failure "Failed to update greeter user"

# All is done!
echo && figlet "All is done!" || echo "== All is done! =="
tarchecho success "Rebooting in 5 seconds..."
sleep 5
reboot